{
  "manifest_version": 3,
  "name": "Phone Scraper Pro",
  "version": "1.0",
  "description": "Automatically identify and save phone numbers from any website you visit.",
  "permissions": [
    "sidePanel",
    "storage",
    "activeTab",
    "scripting"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["scripts/content.js"]
    }
  ],
  "side_panel": {
    "default_path": "sidepanel/sidepanel.html"
  },
  "action": {
    "default_title": "Open Scraper Side Panel"
  },
  "host_permissions": [
    "<all_urls>"
  ]
}
